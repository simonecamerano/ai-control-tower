# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
# claude.ai org ID + full session cookie string (from browser DevTools)
CLAUDE_ORG_ID=
CLAUDE_SESSION_COOKIE=

# platform.claude.com org ID + session cookie (for API prepaid balance)
CLAUDE_PLATFORM_ORG_ID=
CLAUDE_PLATFORM_SESSION_COOKIE=

# ─── GitHub Copilot ───────────────────────────────────────────────────────────
# Full session cookie string from github.com (browser DevTools)
COPILOT_SESSION_COOKIE=

# ─── DeepSeek ─────────────────────────────────────────────────────────────────
# Standard API key from platform.deepseek.com
DEEPSEEK_API_KEY=

# platform.deepseek.com bearer token (for monthly spend data)
DEEPSEEK_PLATFORM_TOKEN=

# ─── Tavily ───────────────────────────────────────────────────────────────────
# Standard API key
TAVILY_API_KEY=

# app.tavily.com session cookie – appSession value only (for quota data)
TAVILY_SESSION_COOKIE=

# ─── OpenAI / Codex ───────────────────────────────────────────────────────────
# No configuration needed — auth is read from ~/.codex/auth.json (written by
# the Codex CLI). API balance is shown automatically if your account has
# pay-as-you-go credits (absent for subscription-only plans).
